# AI chat backend URL the SPA calls (src/services/aiService.ts).
# Production: the Next.js route on the Vercel app.
VITE_AI_ENDPOINT=https://bistro-cloud-orders.vercel.app/api/ai-chat
# Local dev note: point at your local backend instead, e.g.
#   VITE_AI_ENDPOINT=http://localhost:3000/api/ai-chat   (vercel-app `next dev`)

# --- vercel-app server env (set in Vercel, not baked into this SPA bundle) ---
# Groq — API key for /api/ai-chat. Required for the chat to work in production.
# GROQ_API_KEY=
# Optional: where finished plan-builder proposals are forwarded (Apps Script /exec).
# CRM_ENDPOINT=
# Owner-DM Telegram agent (vercel-app): see vercel-app/.env.example for full docs.
# OLLAMA_API_KEY=
# ADMIN_PASS=
# BLOB_READ_WRITE_TOKEN=
