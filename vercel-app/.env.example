# Apps Script web app (existing Bistro Cloud CRM API) — set the real /exec URL in Vercel env
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# Admin role password for gated Apps Script actions — set the real value in Vercel env
APPS_SCRIPT_ADMIN_PASSWORD=changeme
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
# Instapay bank details shown to the customer (free text)
INSTAPAY_DETAILS=Bistro Cloud — Bank: XXX, Account: 000000000000, Name: Bistro Cloud
# Allowed browser origin for CORS
ALLOWED_ORIGIN=https://bistro-cloud.com
# Loyverse POS — API bearer token. When unset, the order-push feature is dormant.
# (Store / POS device / payment-type IDs are non-secret constants in src/lib/loyverse.ts.)
LOYVERSE_TOKEN=
# Resend — API key for customer email (verified domain bistro-cloud.com). When
# unset, email sends are no-ops. Vercel owns customer email (Apps Script lacks
# the OAuth scopes). Set the real value in Vercel env at deploy.
RESEND_API_KEY=
# Groq — API key for the website AI chat backend (/api/ai-chat). When unset, the
# route streams a "Server misconfigured" error. Set the real value in Vercel env.
GROQ_API_KEY=
# Optional Groq model overrides (defaults: chat=llama-3.1-8b-instant,
# plan-builder=llama-3.3-70b-versatile). Verify IDs at console.groq.com/docs/models.
GROQ_MODEL_CHAT=
GROQ_MODEL_PLAN=
# Optional CRM endpoint (Apps Script /exec). When set, finished plan-builder
# proposals are forwarded here. When unset, forwarding is skipped silently.
CRM_ENDPOINT=
# --- Owner-DM Telegram agent ---
# Ollama Cloud API key (agent brain + vision). https://ollama.com
OLLAMA_API_KEY=
# Owner-binding password for /start <ADMIN_PASS> (timing-safe compared). Keep secret.
ADMIN_PASS=
# Vercel Blob store token (agent state: owner/history/pending/claims/audit).
# Set automatically when a Blob store is linked to the project.
BLOB_READ_WRITE_TOKEN=
# Optional Ollama model overrides (defaults shown):
# OLLAMA_MODEL=deepseek-v4-flash:cloud
# OLLAMA_MODEL_HEAVY=deepseek-v4-pro:cloud
# OLLAMA_MODEL_VISION=gemini-3-flash-preview
